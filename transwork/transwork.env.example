# Image tag used by the Gressio Docker overlay.
IMAGE_TAG=transwork-server:latest

# Host path to the Google Cloud service account JSON file.
# Paths are resolved from the repository root when using:
#   docker compose --env-file transwork/transwork.env -f docker-compose.yml -f transwork/docker-compose.transwork.yml up -d --build
TRANSWORK_GCS_KEY_PATH=./transwork/key.json

# Google Cloud Storage bucket for batch ASR uploads.
GCS_BUCKET_NAME=longway-ai

# ElevenLabs API key used by the server for batch transcription.
ELEVENLABS_API_KEY=replace_me
